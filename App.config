<?xml version="1.0" encoding="utf-8" ?>
<configuration>

  <connectionStrings>
    <add name="DefaultConnection"
         connectionString="Data Source=database.db;"
         providerName="Microsoft.Data.Sqlite" />
  </connectionStrings>

  <appSettings>
    
    <!-- Default dollar kursi (agar CurrencyRates jadvali bo'sh bo'lsa ishlatiladi) -->
    <add key="DefaultDollarRate" value="12500"/>

    <!-- Initial login nomlari -->
    <add key="AdminUsername" value="new_admin"/>
    <add key="SellerUsername" value="seller"/>
    <!-- Xavfsizlik uchun bo'sh qoldiring: birinchi ishga tushishda vaqtinchalik kuchli parol avtomatik yaratiladi -->
    <add key="AdminInitialPassword" value=""/>
    <add key="SellerInitialPassword" value=""/>

    <!-- Backup papka -->
    <add key="BackupPath" value="Backup\"/>

    <!-- License aktivatsiya serveri -->
    <add key="ActivationServerUrl" value="https://otserver-production.up.railway.app"/>
    <!-- Velopack release feed manzili (releases.json va paketlar shu yerda turadi) -->
    <add key="VelopackFeedUrl" value="https://raw.githubusercontent.com/botirjon13/OTserver/main/releases"/>
    <add key="SupportContactFallback" value="Aloqa: +998 33 013 19 92"/>

  </appSettings>

</configuration>
